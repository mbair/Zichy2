{
  "name": "nfc-reserve",
  "version": "1.15.50",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:fast": "ng serve --configuration development --hmr",
    "build": "ng build && ng build --output-path docs --base-href /Zichy2/ --configuration production && git add .",
    "watch": "ng build --watch --configuration development",
    "dev": "ng serve --proxy-config proxy.conf.json --ssl --ssl-cert ./localSslCertificate/server.crt --ssl-key ./localSslCertificate/server.key --open --host 0.0.0.0 --disable-host-check",
    "format": "prettier --write \"**/*.{js,mjs,ts,mts,d.ts,html}\" --cache",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "bump:patch": "npm version patch --no-git-tag-version --force"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.0",
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21",
    "@angular/compiler": "^21",
    "@angular/core": "^21",
    "@angular/forms": "^21",
    "@angular/platform-browser": "^21",
    "@angular/platform-browser-dynamic": "^21",
    "@angular/router": "^21",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@primeuix/themes": "^2.0.0",
    "@tailwindcss/postcss": "^4.1.11",
    "chart.js": "4.4.2",
    "file-saver": "^2.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.48",
    "ngx-auto-unsubscribe": "^3.0.1",
    "primeclt": "^0.1.5",
    "primeicons": "^7.0.0",
    "primeng": "^21.0.4",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.7.5",
    "tailwindcss-primeui": "^0.6.1",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21",
    "@angular/cli": "^21",
    "@angular/compiler-cli": "^21",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/lodash": "^4.17.15",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^9.1.7",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.11",
    "typescript": "~5.9.3"
  }
}
