{
  "name": "nfc-reserve",
  "version": "1.15.43",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:fast": "ng serve --configuration development --hmr",
    "build": "ng build && ng build --output-path docs --base-href /Zichy2/ --configuration production && git add .",
    "watch": "ng build --watch --configuration development",
    "dev": "ng serve --ssl --ssl-cert ./localSslCertificate/server.crt --ssl-key ./localSslCertificate/server.key --open --host 0.0.0.0 --disable-host-check",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "bump:patch": "npm version patch --no-git-tag-version --force"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "20.3.17",
    "@angular/cdk": "20.2.14",
    "@angular/common": "20.3.17",
    "@angular/compiler": "20.3.17",
    "@angular/core": "20.3.17",
    "@angular/forms": "20.3.17",
    "@angular/platform-browser": "20.3.17",
    "@angular/platform-browser-dynamic": "20.3.17",
    "@angular/router": "20.3.17",
    "@fullcalendar/angular": "^6.0.3",
    "@fullcalendar/core": "^6.0.3",
    "@fullcalendar/daygrid": "^6.0.3",
    "@fullcalendar/interaction": "^6.0.3",
    "@fullcalendar/timegrid": "^6.0.3",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "chart.js": "^3.3.2",
    "file-saver": "^2.0.5",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.48",
    "ngx-auto-unsubscribe": "^3.0.1",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "20.3.0",
    "quill": "^2.0.2",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.7.5",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.18",
    "@angular/cli": "20.3.18",
    "@angular/compiler-cli": "20.3.17",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.0",
    "@types/lodash": "^4.17.15",
    "husky": "^9.1.7",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.3"
  }
}
